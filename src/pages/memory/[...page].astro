---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { page: undefined } }];
}
---

<BaseLayout
  title="Memory"
  description="Embark on a journey of personal insights and experiences through my blog"
  image={{ src: '/dante-preview.jpg', alt: 'The preview of the site' }}
  showHeader={false}
>
  <script>
    const now = new Date();
    const mm = String(now.getMonth() + 1).padStart(2, '0');
    const dd = String(now.getDate()).padStart(2, '0');
    window.location.replace(`/memory/${now.getFullYear()}/${mm}/${dd}`);
  </script>
</BaseLayout>
